{
  "info": {
    "_postman_id": "8a5f7a9d-1b27-4f56-b101-multi-courier",
    "name": "Multi Courier API",
    "description": "Postman collection for the Multi Courier Django REST API with UrbaneBolt as the active courier. Run Signup or Login first; the collection saves tokens.access into access_token automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "order_id",
      "value": "ORD-1001"
    },
    {
      "key": "batch_id",
      "value": ""
    },
    {
      "key": "webhook_secret",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.tokens.access);",
                  "  pm.collectionVariables.set('refresh_token', json.tokens.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"strong-pass-123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signup/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "signup",
                ""
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('access_token', json.tokens.access);",
                  "  pm.collectionVariables.set('refresh_token', json.tokens.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"strong-pass-123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login",
                ""
              ]
            }
          }
        }
      ]
    },
    {
